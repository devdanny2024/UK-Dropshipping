generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PLACED
  PENDING_INVOICE
  INVOICED
  PROCESSING
  AWAITING_PURCHASE
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  RECEIVED
  CAPTURED
  FAILED
}

// M2/M3 — region drives currency, service-charge rule and basket separation.
enum Region {
  UK
  US
}

// M2 — two independent delivery legs, each STD or EXPRESS (EXPRESS is UK-only).
enum DeliverySpeed {
  STD
  EXPRESS
}

// M2 — invoice lifecycle.
enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

// M3 R15 — user roles for the admin role-management engine.
enum Role {
  CUSTOMER
  STAFF
  ADMIN
  SUPER_ADMIN
}

// M3 R9 — per-item weight-pricing state (manual quote for no-weight categories).
enum WeightPriceStatus {
  AUTO
  REQUESTED
  PRICED
}

// M3 R10 — complaints (replaces the M2 refund/dispute concept).
enum ComplaintStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

// M3 R13 — virtual wallet ledger entry direction.
enum WalletTxnType {
  CREDIT
  DEBIT
}

enum PurchaseAttemptStatus {
  QUEUED
  RUNNING
  FAILED
  SUCCESS
}

enum AdapterHealthStatus {
  UNKNOWN
  ONLINE
  OFFLINE
}

enum ShipmentStatus {
  CREATED
  IN_TRANSIT
  DELIVERED
  ISSUE
}

enum AddressType {
  SHIPPING
  BILLING
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  passwordHash String?
  googleId  String?   @unique
  phone     String?
  emailVerifiedAt DateTime?
  createdAt DateTime  @default(now())
  // M3 R15 — role management
  role            Role      @default(CUSTOMER)
  roleUpdatedAt   DateTime?
  roleUpdatedById String?
  addresses Address[]
  orders    Order[]
  sessions  Session[]
  emailVerifications EmailVerificationToken[]
  passwordResets PasswordResetToken[]
  // M3 R13 — virtual wallet
  wallet    Wallet?
  complaints Complaint[]
  quotes    Quote[]

  @@index([role])
}

model Address {
  id         String   @id @default(cuid())
  userId     String?
  label      String?
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String
  country    String
  phone      String?
  type       AddressType @default(SHIPPING)
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
  orders     Order[]
  quotes     Quote[]
}

model ProductSnapshot {
  id        String   @id @default(cuid())
  url       String
  title     String
  imageUrl  String?
  price     Float
  currency  String
  raw       Json
  createdAt DateTime @default(now())
  quotes    Quote[]
  items     OrderItem[]
}

model Quote {
  id                    String   @id @default(cuid())
  productSnapshotId     String
  size                  String
  color                 String
  qty                   Int
  subtotal              Float
  shipping              Float
  tax                   Float
  total                 Float
  currency              String
  addressId             String
  itemWeightGrams       Int?
  chargeableWeightGrams Int?
  userId                String?
  createdAt             DateTime @default(now())
  productSnapshot       ProductSnapshot @relation(fields: [productSnapshotId], references: [id])
  address               Address         @relation(fields: [addressId], references: [id])
  user                  User?           @relation(fields: [userId], references: [id])
}

model Order {
  id         String       @id @default(cuid())
  userId     String?
  addressId  String?
  status     OrderStatus
  // M2 — region drives currency + pricing rules (UK £ / US $)
  region     Region       @default(UK)
  currency   String
  total      Float
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  // M2 — Delivery Engine snapshot (taken at quote time so estimates don't drift)
  leg1Speed       DeliverySpeed?
  leg2Speed       DeliverySpeed?
  despatchDate    DateTime?
  estDeliveryMin  DateTime?
  estDeliveryMax  DateTime?
  deliveryQuotedAt DateTime?
  deliveryNote    Json?
  user       User?        @relation(fields: [userId], references: [id])
  address    Address?     @relation(fields: [addressId], references: [id])
  items      OrderItem[]
  payments   Payment[]
  attempts   PurchaseAttempt[]
  shipments  Shipment[]
  events     OrderEvent[]
  invoice    Invoice?
  weightPriceRequests WeightPriceRequest[]
  complaints Complaint[]

  @@index([status])
  @@index([region])
}

model OrderItem {
  id                String   @id @default(cuid())
  orderId           String
  productSnapshotId String
  qty               Int
  size              String
  color             String
  unitPrice         Float
  total             Float
  // M3 R9 — manual weight pricing for no-weight categories
  weightStatus        WeightPriceStatus @default(AUTO)
  manualDeliveryPrice Float?
  manualPriceCurrency String?
  // Weight-based Nigeria postage — resolved chargeable weight per item (null = manual/unknown)
  chargeableWeightGrams Int?
  order             Order           @relation(fields: [orderId], references: [id])
  productSnapshot   ProductSnapshot @relation(fields: [productSnapshotId], references: [id])
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String?
  paymentRef      String
  provider        String
  amount          Float
  currency        String
  status          PaymentStatus
  idempotencyKey  String        @unique
  gatewayRef      String?
  gatewayTxId     String?
  paidAt          DateTime?
  rawPayload      Json?
  createdAt       DateTime      @default(now())
  order           Order?        @relation(fields: [orderId], references: [id])
}

model PurchaseAttempt {
  id              String                @id @default(cuid())
  orderId         String
  status          PurchaseAttemptStatus
  note            String?
  idempotencyKey  String                @unique
  createdAt       DateTime              @default(now())
  order           Order                 @relation(fields: [orderId], references: [id])
}

model Shipment {
  id             String         @id @default(cuid())
  orderId        String
  carrier        String
  trackingNumber String
  status         ShipmentStatus
  createdAt      DateTime       @default(now())
  order          Order          @relation(fields: [orderId], references: [id])
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  type      String
  message   String
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Category {
  id                           String   @id @default(cuid())
  name                         String
  slug                         String   @unique
  description                  String?
  imageUrl                     String?
  isActive                     Boolean  @default(true)
  sortOrder                    Int      @default(0)
  defaultWeightGrams           Int?
  defaultChargeableWeightGrams Int?
  // M3 R9 — flag categories that have no weight class (force manual weight pricing)
  requiresManualWeight         Boolean  @default(false)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  products                     Product[]

  @@index([isActive])
  @@index([sortOrder])
}

model Product {
  id                    String   @id @default(cuid())
  categoryId            String
  category              Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name                  String
  slug                  String   @unique
  description           String?
  images                Json?
  productCode           String?
  externalUrl           String?
  priceGBP              Decimal? @db.Decimal(10, 2)
  currency              String   @default("GBP")
  isActive              Boolean  @default(true)
  isFeatured            Boolean  @default(false)
  featuredOrder         Int      @default(0)
  weightGrams           Int?
  chargeableWeightGrams Int?
  sizes                 Json?
  gender                String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([categoryId])
  @@index([isFeatured])
  @@index([isActive])
}

model AdapterState {
  id          String              @id
  name        String
  domain      String              @unique
  region      String
  enabled     Boolean             @default(true)
  status      AdapterHealthStatus @default(UNKNOWN)
  lastCheckAt DateTime?
  notes       String?
  // M3 R14 — store → UK-warehouse delivery fee (admin-managed, used by invoice math)
  storeToWarehouseFee Float?
  storeFeeCurrency    String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([enabled])
  @@index([status])
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// Weight reference table — stores category fallbacks and named product weights
model WeightReference {
  id                    String   @id @default(cuid())
  // e.g. "womens_clothing", "footwear", "electronics"
  category              String
  // e.g. "t-shirt", "jeans", or a named product like "Court Heels UK8 Female"
  label                 String
  // actual weight in grams (optional — may only have chargeable)
  actualWeightGrams     Int?
  // chargeable/billable weight in grams used for shipping cost
  chargeableWeightGrams Int
  // if true this is a named product entry (real shipment data), else a category fallback
  isNamedProduct        Boolean  @default(false)
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([category, label])
  @@index([category])
  @@index([isNamedProduct])
}

// ── M2: Invoicing ───────────────────────────────────────────────────────────

model Invoice {
  id                       String        @id @default(cuid())
  orderId                  String        @unique
  invoiceNumber            String        @unique
  region                   Region
  currency                 String
  status                   InvoiceStatus @default(DRAFT)
  // Money breakdown (mirrors how staff build invoices in Excel)
  itemsSubtotal            Float         @default(0)
  storePostage             Float         @default(0)
  salesTax                 Float         @default(0)
  internationalTransferFee Float         @default(0)
  serviceCharge            Float         @default(0)
  nigeriaPostage           Float         @default(0)
  domesticPostage          Float         @default(0)
  total                    Float         @default(0)
  fxRateSnapshot           Float?
  notes                    String?
  sentAt                   DateTime?
  dueAt                    DateTime?
  paidAt                   DateTime?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  order                    Order         @relation(fields: [orderId], references: [id])
  lineItems                InvoiceLineItem[]

  @@index([status])
}

model InvoiceLineItem {
  id           String  @id @default(cuid())
  invoiceId    String
  storeName    String          // group key — all items from one store sit together
  productTitle String
  productUrl   String
  size         String?
  color        String?
  qty          Int
  unitPrice    Float
  lineTotal    Float
  weightGrams  Int?
  invoice      Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ── M3 R9: Manual weight pricing ────────────────────────────────────────────

model WeightPriceRequest {
  id            String            @id @default(cuid())
  orderId       String
  orderItemId   String?
  productUrl    String
  category      String?
  status        WeightPriceStatus @default(REQUESTED)
  resolvedPrice Float?
  currency      String?
  requestedById String?
  resolvedById  String?
  createdAt     DateTime          @default(now())
  resolvedAt    DateTime?
  order         Order             @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

// ── M3 R10: Complaints (replaces M2 refund/dispute) ─────────────────────────

model Complaint {
  id             String          @id @default(cuid())
  orderId        String
  userId         String?
  reason         String
  detail         String?
  status         ComplaintStatus @default(OPEN)
  resolutionNote String?
  resolvedById   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  resolvedAt     DateTime?
  order          Order           @relation(fields: [orderId], references: [id])
  user           User?           @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([status])
}

// ── M3 R13: Virtual Wallet ──────────────────────────────────────────────────

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  txns      WalletTransaction[]
}

model WalletTransaction {
  id           String        @id @default(cuid())
  walletId     String
  type         WalletTxnType
  amount       Float
  currency     String        // GBP | USD — balances are tracked per currency
  reason       String
  orderId      String?
  paymentId    String?
  balanceAfter Float
  createdById  String?
  createdAt    DateTime      @default(now())
  wallet       Wallet        @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([currency])
}
